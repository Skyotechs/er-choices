{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "prebuildCommand": "./node_modules/.bin/expo prebuild"
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "prebuildCommand": "./node_modules/.bin/expo prebuild"
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "./node_modules/.bin/expo prebuild"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "language": "en-US",
        "appName": "ER Choices"
      }
    }
  }
}
